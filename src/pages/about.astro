---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Ranamo Edu',
  url: 'https://ranomoedu.com',
  description: 'AI-powered study abroad consulting helping Indian students access world-class education.',
  foundingDate: '2015',
  numberOfEmployees: { '@type': 'QuantitativeValue', value: 25 },
};
---

<BaseLayout
  title="About Us"
  description="Learn about Ranamo Edu — AI-powered study abroad consulting helping Indian students access world-class education. Expert counselors, 2,000+ students placed."
  schema={schema}
>
  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-(--color-primary) to-(--color-primary-dark) text-white py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-blue-200">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">About</li>
          </ol>
        </nav>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">About Ranamo Edu</h1>
        <p class="text-xl text-blue-100 max-w-3xl">Empowering Indian students to access world-class education through AI-powered guidance and expert counseling.</p>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-20 bg-(--color-bg)">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div data-aos="fade-up">
          <span class="text-(--color-primary) font-semibold text-sm uppercase tracking-wider">Our Mission</span>
          <h2 class="text-3xl font-bold text-(--color-dark) mt-2 mb-4">Every Student Deserves a World-Class Education</h2>
          <p class="text-(--color-text) leading-relaxed mb-4">
            We are on a mission to revolutionize the way students pursue their study abroad journey by combining the power of AI with the expertise of experienced counsellors. Our platform simplifies complex decisions and empowers students with the right insights to confidently choose their future.
          </p>
          <p class="text-(--color-text) leading-relaxed">
            With a strong student-first approach, we are committed to delivering exceptional service and ensuring a smooth, transparent, and stress-free experience for every student.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4" data-aos="fade-up" data-aos-delay="100">
          {[
            { value: '2,000+', label: 'Students Placed' },
            { value: '98%', label: 'Visa Success Rate' },
            { value: '₹50 Cr+', label: 'Scholarships Won' },
            { value: '10+', label: 'Years of Experience' },
          ].map(({ value, label }) => (
            <div class="rounded-2xl bg-white border border-(--color-border) p-6 text-center shadow-sm">
              <div class="text-3xl font-bold text-(--color-primary)">{value}</div>
              <div class="text-sm text-(--color-text-muted) mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-(--color-primary) text-white text-center">
      <div class="mx-auto max-w-2xl px-4">
        <h2 class="text-3xl font-bold mb-4" data-aos="fade-up">Ready to Begin Your Journey?</h2>
        <p class="text-blue-100 mb-8" data-aos="fade-up">Book a consultation with our team today.</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-(--color-accent) text-white px-8 py-4 rounded-xl font-bold hover:bg-(--color-accent-dark) transition-colors" data-aos="fade-up">
          Book Consultation →
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
