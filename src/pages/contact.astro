---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/sections/ContactForm.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Ranomo Edu',
  url: 'https://ranomoedu.com',
  telephone: '+91-98765-43210',
  email: 'hello@ranomoedu.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '123 MG Road',
    addressLocality: 'Bengaluru',
    addressRegion: 'Karnataka',
    postalCode: '560001',
    addressCountry: 'IN',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '19:00',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 12.9716,
    longitude: 77.5946,
  },
};
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Ranomo Edu — book a free study abroad consultation, or send us a message. We respond within 24 hours."
  schema={schema}
>
  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-(--color-primary) to-(--color-primary-dark) text-white py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-blue-200">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">Contact</li>
          </ol>
        </nav>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Get in Touch</h1>
        <p class="text-xl text-blue-100 max-w-2xl">
          Book a free consultation or drop us a message. Our counselors will respond within 24 hours.
        </p>
      </div>
    </section>

    <!-- Main content -->
    <section class="py-20 bg-(--color-bg)">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

          <!-- Contact form -->
          <div class="bg-white rounded-2xl border border-(--color-border) p-8 shadow-sm" data-aos="fade-up">
            <h2 class="text-2xl font-bold text-(--color-dark) mb-2">Send Us a Message</h2>
            <p class="text-(--color-text-muted) text-sm mb-6">Fill in the form and a counselor will reach out to you.</p>
            <ContactForm />
          </div>

          <!-- Contact info + map -->
          <div class="space-y-6" data-aos="fade-up" data-aos-delay="100">

            <!-- Info cards -->
            <div class="bg-white rounded-2xl border border-(--color-border) p-8 shadow-sm">
              <h2 class="text-2xl font-bold text-(--color-dark) mb-6">Contact Information</h2>

              <div class="space-y-5">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-(--color-primary) flex-none">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1">Email</div>
                    <a href="mailto:hello@ranomoedu.com" class="font-semibold text-(--color-dark) hover:text-(--color-primary) transition-colors">
                      hello@ranomoedu.com
                    </a>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-(--color-primary) flex-none">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 5.36 5.36l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 15.5v1.42z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1">Phone</div>
                    <a href="tel:+919876543210" class="font-semibold text-(--color-dark) hover:text-(--color-primary) transition-colors">
                      +91 98765 43210
                    </a>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-[#25d366] flex-none">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1">WhatsApp</div>
                    <a
                      href="https://wa.me/919876543210?text=Hi%2C+I%27d+like+to+know+more+about+studying+abroad"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-semibold text-[#25d366] hover:underline"
                    >
                      Chat Now →
                    </a>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-(--color-primary) flex-none">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1">Office</div>
                    <address class="not-italic font-semibold text-(--color-dark) text-sm leading-relaxed">
                      123 MG Road<br />Bengaluru, Karnataka 560001<br />India
                    </address>
                    <div class="text-xs text-(--color-text-muted) mt-1">Mon–Sat · 9am–7pm IST</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Google Maps embed placeholder -->
            <div class="rounded-2xl overflow-hidden border border-(--color-border) shadow-sm">
              <iframe
                title="Ranomo Edu office location"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3887.9761808027527!2d77.5940!3d12.9716!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bae1670c9b44e6d%3A0xf8dfc3e8517e4fe0!2sMG%20Road%2C%20Bengaluru%2C%20Karnataka!5e0!3m2!1sen!2sin!4v1714000000000!5m2!1sen!2sin"
                width="100%"
                height="260"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust strip -->
    <section class="py-12 bg-white border-t border-(--color-border)">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap justify-center gap-8 text-center text-sm text-(--color-text-muted)">
          <div>
            <div class="text-2xl font-bold text-(--color-primary)">5,000+</div>
            <div>Students Placed</div>
          </div>
          <div class="hidden sm:block w-px bg-(--color-border)"></div>
          <div>
            <div class="text-2xl font-bold text-(--color-primary)">98%</div>
            <div>Visa Success Rate</div>
          </div>
          <div class="hidden sm:block w-px bg-(--color-border)"></div>
          <div>
            <div class="text-2xl font-bold text-(--color-primary)">Free</div>
            <div>Initial Consultation</div>
          </div>
          <div class="hidden sm:block w-px bg-(--color-border)"></div>
          <div>
            <div class="text-2xl font-bold text-(--color-primary)">24hr</div>
            <div>Response Time</div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
