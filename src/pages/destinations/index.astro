---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DestinationCard from '@/components/DestinationCard.astro';
import { destinations } from '@/data/destinations';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ranomoedu.com/' },
    { '@type': 'ListItem', position: 2, name: 'Destinations', item: 'https://ranomoedu.com/destinations/' },
  ],
};
---

<BaseLayout
  title="Study Abroad Destinations"
  description="Explore 7 top study abroad destinations — UK, USA, Canada, Australia, Germany, New Zealand, and Ireland. Compare universities, costs, visa requirements, and career opportunities."
  schema={breadcrumbSchema}
>
  <main>
    <!-- Page hero -->
    <section class="bg-gradient-to-br from-(--color-primary) to-(--color-primary-dark) text-white py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-blue-200">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">Destinations</li>
          </ol>
        </nav>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Study Abroad Destinations</h1>
        <p class="text-lg text-blue-100 max-w-2xl">
          Discover the best countries for international education. Each destination offers unique academic strengths, career pathways, and a welcoming environment for students from India.
        </p>
      </div>
    </section>

    <!-- Destination grid -->
    <section class="py-20 bg-(--color-bg)">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {destinations.map((dest, i) => (
            <div data-aos="fade-up" data-aos-delay={i * 80}>
              <DestinationCard destination={dest} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white border-t border-(--color-border)">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-(--color-dark) mb-4">Not sure which country is right for you?</h2>
        <p class="text-(--color-text-muted) mb-8">Book a free consultation. Our counselors will analyze your profile, budget, and career goals to recommend the best destination for you.</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-(--color-primary) text-white px-8 py-4 rounded-xl font-semibold hover:bg-(--color-primary-dark) transition-colors shadow-md">
          Book Free Consultation →
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
