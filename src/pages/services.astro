---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Study Abroad Services — Ranomo Edu',
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: s.title,
      description: s.shortDesc,
      provider: { '@type': 'EducationalOrganization', name: 'Ranomo Edu' },
    },
  })),
};
---

<BaseLayout
  title="Study Abroad Services"
  description="Comprehensive study abroad services — university selection, application support, visa assistance, scholarship guidance, test preparation, and pre-departure support."
  schema={schema}
>
  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-(--color-primary) to-(--color-primary-dark) text-white py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-blue-200">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">Services</li>
          </ol>
        </nav>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Our Services</h1>
        <p class="text-xl text-blue-100 max-w-3xl">End-to-end study abroad support — from your first research to your first day on campus.</p>
      </div>
    </section>

    <!-- Services list -->
    <section class="py-20 bg-(--color-bg)">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-10">
        {services.map((service, i) => (
          <article
            id={service.slug}
            class="rounded-2xl border border-(--color-border) bg-white p-8 shadow-sm scroll-mt-24"
            data-aos="fade-up"
            data-aos-delay={i * 60}
          >
            <div class="flex flex-col sm:flex-row gap-6">
              <div class="flex-none w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center text-(--color-primary) text-2xl">
                {service.icon === 'GraduationCap' && '🎓'}
                {service.icon === 'FileText' && '📄'}
                {service.icon === 'Stamp' && '✈️'}
                {service.icon === 'Award' && '🏆'}
                {service.icon === 'BookOpen' && '📚'}
                {service.icon === 'Plane' && '🌍'}
              </div>
              <div class="flex-1">
                <h2 class="text-xl font-bold text-(--color-dark) mb-2">{service.title}</h2>
                <p class="text-(--color-text-muted) mb-4">{service.longDesc}</p>

                <h3 class="text-sm font-semibold text-(--color-dark) mb-2 uppercase tracking-wider">What's included:</h3>
                <ul class="space-y-1.5">
                  {service.includes.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-(--color-text)">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4 text-green-500 flex-none mt-0.5" aria-hidden="true">
                        <path d="M20 6L9 17l-5-5"/>
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-(--color-primary) text-white text-center">
      <div class="mx-auto max-w-2xl px-4">
        <h2 class="text-3xl font-bold mb-4">Get Started with a Free Consultation</h2>
        <p class="text-blue-100 mb-8">Talk to a counselor and find out exactly which services apply to your situation.</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-white text-(--color-primary) px-8 py-4 rounded-xl font-bold hover:bg-blue-50 transition-colors">
          Book Free Consultation →
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
