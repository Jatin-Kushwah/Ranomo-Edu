---
import Button from '@/components/ui/Button.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/destinations', label: 'Destinations' },
  { href: '/services', label: 'Services' },
  { href: '/success-stories', label: 'Success Stories' },
  { href: '/blog', label: 'Blog' },
];

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  class="sticky top-0 z-40 w-full border-b border-(--color-border) bg-white/95 backdrop-blur-sm"
  transition:persist
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-(--color-primary) font-bold text-xl">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-8 w-8" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="16" fill="currentColor"/>
        <circle cx="16" cy="16" r="9" stroke="white" stroke-width="1.2" fill="none"/>
        <ellipse cx="16" cy="16" rx="4.5" ry="9" stroke="white" stroke-width="1.2" fill="none"/>
        <line x1="7" y1="16" x2="25" y2="16" stroke="white" stroke-width="1.2"/>
        <polygon points="16,4 21,8 16,12 11,8" fill="#f59e0b"/>
      </svg>
      Ranomo Edu
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            isActive(href)
              ? 'text-(--color-primary) bg-blue-50'
              : 'text-(--color-text-muted) hover:text-(--color-text) hover:bg-gray-50'
          }`}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA + Mobile toggle -->
    <div class="flex items-center gap-3">
      <Button href="/contact" variant="primary" class="hidden sm:inline-flex">
        Free Consultation
      </Button>

      <!-- Hamburger toggle -->
      <label
        for="nav-toggle"
        class="lg:hidden flex flex-col gap-1.5 cursor-pointer p-2"
        aria-label="Toggle navigation menu"
      >
        <span class="block h-0.5 w-6 bg-(--color-dark) transition-all duration-300 nav-bar-1"></span>
        <span class="block h-0.5 w-6 bg-(--color-dark) transition-all duration-300 nav-bar-2"></span>
        <span class="block h-0.5 w-6 bg-(--color-dark) transition-all duration-300 nav-bar-3"></span>
      </label>
    </div>
  </div>

  <!-- Hidden checkbox for CSS-only toggle -->
  <input type="checkbox" id="nav-toggle" class="hidden peer" aria-hidden="true" />

  <!-- Mobile drawer -->
  <div class="lg:hidden overflow-hidden max-h-0 peer-checked:max-h-[500px] transition-all duration-300 ease-in-out border-t border-(--color-border) bg-white">
    <nav class="flex flex-col px-4 py-4 gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`px-4 py-3 rounded-md text-sm font-medium transition-colors ${
            isActive(href)
              ? 'text-(--color-primary) bg-blue-50'
              : 'text-(--color-text) hover:bg-gray-50'
          }`}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  #nav-toggle:checked ~ * .nav-bar-1 {
    transform: rotate(45deg) translate(5px, 5px);
  }
  #nav-toggle:checked ~ * .nav-bar-2 {
    opacity: 0;
  }
  #nav-toggle:checked ~ * .nav-bar-3 {
    transform: rotate(-45deg) translate(5px, -5px);
  }
</style>
