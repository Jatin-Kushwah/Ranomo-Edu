---
import { destinations } from '@/data/destinations';
---

<section class="py-20 bg-(--color-bg)" aria-labelledby="destinations-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-aos="fade-up">
      <span class="text-(--color-primary) font-semibold text-sm uppercase tracking-wider">Where Will You Study?</span>
      <h2 id="destinations-heading" class="text-3xl sm:text-4xl font-bold text-(--color-dark) mt-2">
        Top Study Destinations
      </h2>
      <p class="text-(--color-text-muted) mt-4 max-w-2xl mx-auto">
        Choose from 7 globally recognized destinations — each offering world-class education, unique career pathways, and a welcoming environment for international students.
      </p>
    </div>

    <!-- Mobile: horizontal scroll; md+: grid -->
    <div class="flex gap-4 overflow-x-auto pb-4 hide-scrollbar md:hidden">
      {destinations.map((dest, i) => (
        <a
          href={`/destinations/${dest.slug}`}
          class="flex-none w-44 rounded-2xl bg-white border border-(--color-border) p-5 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 group"
          data-aos="fade-up"
          data-aos-delay={i * 60}
        >
          <span class={`fi fi-${dest.isoCode} text-3xl rounded`} aria-hidden="true"></span>
          <div class="mt-3 font-semibold text-(--color-dark) text-sm">{dest.name}</div>
          <div class="text-xs text-(--color-text-muted) mt-1 line-clamp-2">{dest.tagline}</div>
          <div class="mt-3 text-xs text-(--color-primary) font-medium group-hover:underline">
            Explore →
          </div>
        </a>
      ))}
    </div>

    <!-- Desktop: grid -->
    <div class="hidden md:grid md:grid-cols-4 lg:grid-cols-7 gap-4">
      {destinations.map((dest, i) => (
        <a
          href={`/destinations/${dest.slug}`}
          class="rounded-2xl bg-white border border-(--color-border) p-5 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 group text-center"
          data-aos="fade-up"
          data-aos-delay={i * 60}
        >
          <span class={`fi fi-${dest.isoCode} text-4xl rounded block mx-auto`} aria-hidden="true"></span>
          <div class="mt-3 font-semibold text-(--color-dark) text-sm">{dest.name}</div>
          <div class="text-xs text-(--color-text-muted) mt-1 line-clamp-2">{dest.tagline}</div>
          <div class="mt-3 text-xs text-(--color-primary) font-medium group-hover:underline">
            Explore →
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10" data-aos="fade-up">
      <a href="/destinations" class="inline-flex items-center gap-2 text-(--color-primary) font-semibold hover:underline">
        View all destinations
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
