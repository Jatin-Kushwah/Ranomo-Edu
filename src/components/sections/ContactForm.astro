---
import { destinations } from '@/data/destinations';
import Button from '@/components/ui/Button.astro';
---

<div>
  <!-- Success banner (hidden until ?submitted=true detected by JS) -->
  <div
    id="success-banner"
    class="hidden mb-6 rounded-xl bg-green-50 border border-green-200 p-5 text-center"
    role="alert"
    aria-live="polite"
  >
    <div class="text-2xl mb-2">🎉</div>
    <h3 class="font-bold text-green-800 text-lg">Message Sent!</h3>
    <p class="text-green-700 text-sm mt-1">
      Thank you for reaching out. One of our counselors will get back to you within 24 hours.
    </p>
  </div>

  <form
    name="contact"
    method="POST"
    data-netlify="true"
    action="/contact?submitted=true"
    data-netlify-honeypot="bot-field"
    class="space-y-5"
    novalidate
  >
    <!-- Netlify required hidden field -->
    <input type="hidden" name="form-name" value="contact" />

    <!-- Honeypot -->
    <div class="hidden" aria-hidden="true">
      <label>
        Don't fill this out if you're human:
        <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <!-- Name -->
    <div>
      <label for="name" class="block text-sm font-semibold text-(--color-dark) mb-1.5">
        Full Name <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        maxlength="100"
        placeholder="Your full name"
        class="w-full px-4 py-3 rounded-xl border border-(--color-border) bg-white text-(--color-dark) placeholder-(--color-text-muted) focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:border-transparent transition"
      />
    </div>

    <!-- Email -->
    <div>
      <label for="email" class="block text-sm font-semibold text-(--color-dark) mb-1.5">
        Email Address <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-full px-4 py-3 rounded-xl border border-(--color-border) bg-white text-(--color-dark) placeholder-(--color-text-muted) focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:border-transparent transition"
      />
    </div>

    <!-- Phone -->
    <div>
      <label for="phone" class="block text-sm font-semibold text-(--color-dark) mb-1.5">
        Phone Number <span class="text-(--color-text-muted) text-xs font-normal">(optional)</span>
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+91 98765 43210"
        class="w-full px-4 py-3 rounded-xl border border-(--color-border) bg-white text-(--color-dark) placeholder-(--color-text-muted) focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:border-transparent transition"
      />
    </div>

    <!-- Country of Interest -->
    <div>
      <label for="country" class="block text-sm font-semibold text-(--color-dark) mb-1.5">
        Country of Interest <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <select
        id="country"
        name="country"
        required
        class="w-full px-4 py-3 rounded-xl border border-(--color-border) bg-white text-(--color-dark) focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:border-transparent transition appearance-none"
      >
        <option value="" disabled selected>Select a destination…</option>
        {destinations.map((d) => (
          <option value={d.name}>{d.name}</option>
        ))}
        <option value="Not decided yet">Not decided yet</option>
      </select>
    </div>

    <!-- Message -->
    <div>
      <label for="message" class="block text-sm font-semibold text-(--color-dark) mb-1.5">
        Your Message <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <textarea
        id="message"
        name="message"
        required
        minlength="10"
        maxlength="1000"
        rows="5"
        placeholder="Tell us about your academic background, which courses interest you, and your target intake year…"
        class="w-full px-4 py-3 rounded-xl border border-(--color-border) bg-white text-(--color-dark) placeholder-(--color-text-muted) focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:border-transparent transition resize-none"
      ></textarea>
      <p class="text-xs text-(--color-text-muted) mt-1">Minimum 10 characters, maximum 1,000.</p>
    </div>

    <Button type="submit" variant="primary" class="w-full justify-center py-4 text-base">
      Send Message
    </Button>

    <p class="text-xs text-center text-(--color-text-muted)">
      We respond within 24 hours · Mon–Sat, 9am–7pm IST · Your data is never shared
    </p>
  </form>
</div>

<script>
  if (window.location.search.includes('submitted=true')) {
    const banner = document.getElementById('success-banner');
    if (banner) {
      banner.style.display = 'block';
      banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
