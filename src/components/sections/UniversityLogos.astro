---
import { universities } from '@/data/universities';

// Duplicate list for seamless infinite marquee
const doubled = [...universities, ...universities];
---

<section class="py-16 bg-(--color-bg) overflow-hidden" aria-labelledby="universities-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-10" data-aos="fade-up">
    <div class="text-center">
      <span class="text-(--color-primary) font-semibold text-sm uppercase tracking-wider">Our Placement Record</span>
      <h2 id="universities-heading" class="text-3xl sm:text-4xl font-bold text-(--color-dark) mt-2">
        Students Placed at Top Universities
      </h2>
    </div>
  </div>

  <!-- Marquee track -->
  <div class="relative" aria-hidden="true">
    <div class="marquee-track flex gap-4 w-max">
      {doubled.map((uni, i) => (
        <div
          key={i}
          class="flex-none w-52 rounded-xl border border-(--color-border) bg-white p-4 shadow-sm"
        >
          <div class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1">{uni.country}</div>
          <div class="font-bold text-(--color-dark) text-sm leading-tight">{uni.name}</div>
          <div class="mt-2 inline-block px-2 py-0.5 rounded-full bg-blue-50 text-(--color-primary) text-xs font-semibold">
            {uni.ranking}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
