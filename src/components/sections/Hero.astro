---
import Button from '@/components/ui/Button.astro';
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-(--color-primary) via-(--color-primary-dark) to-[#0a1628]">
  <!-- Background decorative circles -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-20 -right-20 w-96 h-96 rounded-full bg-white/5"></div>
    <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full bg-white/5"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-white/3 border border-white/10"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Text content -->
      <div class="text-white">
        <span class="inline-block px-4 py-1.5 rounded-full bg-(--color-accent)/20 text-(--color-accent) text-sm font-semibold mb-6 border border-(--color-accent)/30">
          🎓 Trusted by 5,000+ Students
        </span>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Your Dream University<br />
          <span class="text-(--color-accent)">Starts Here</span>
        </h1>

        <p class="text-lg sm:text-xl text-blue-100 mb-8 leading-relaxed max-w-lg">
          Expert study abroad counseling for UK, USA, Canada, Australia, Germany, New Zealand, and Ireland. From university selection to visa approval — we guide you every step of the way.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <Button href="/contact" variant="primary" class="bg-(--color-accent) hover:bg-(--color-accent-dark) text-white border-none shadow-xl text-base px-8 py-4">
            Book Free Consultation
          </Button>
          <Button href="/destinations" variant="outline" class="border-white/40 text-white hover:bg-white/10 hover:border-white text-base px-8 py-4">
            Explore Destinations
          </Button>
        </div>

        <!-- Stats strip -->
        <div class="flex flex-wrap gap-6 pt-8 border-t border-white/20">
          {[
            { value: '5,000+', label: 'Students Placed' },
            { value: '200+', label: 'Universities' },
            { value: '15+', label: 'Countries' },
            { value: '98%', label: 'Visa Success' },
          ].map(({ value, label }) => (
            <div class="text-center">
              <div class="text-2xl font-bold text-(--color-accent)">{value}</div>
              <div class="text-xs text-blue-200 mt-0.5">{label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Visual / illustration side -->
      <div class="hidden lg:flex items-center justify-center" aria-hidden="true">
        <div class="relative w-full max-w-md">
          <!-- Decorative card stack -->
          <div class="absolute top-0 right-4 w-56 h-36 rounded-2xl bg-white/10 backdrop-blur border border-white/20 rotate-6"></div>
          <div class="absolute top-4 right-0 w-56 h-36 rounded-2xl bg-white/10 backdrop-blur border border-white/20 -rotate-3"></div>

          <!-- Main "card" -->
          <div class="relative bg-white/15 backdrop-blur-lg rounded-3xl border border-white/30 p-8 shadow-2xl">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-full bg-(--color-accent) flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="20" height="20" aria-hidden="true">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
              </div>
              <div>
                <div class="text-white font-semibold text-sm">Application Submitted</div>
                <div class="text-blue-200 text-xs">University of Toronto</div>
              </div>
            </div>

            <div class="space-y-3">
              {['Profile Assessment', 'University Shortlisting', 'SOP Review', 'Visa Filing'].map((step, i) => (
                <div class="flex items-center gap-3">
                  <div class={`w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 ${i < 3 ? 'bg-green-400 text-white' : 'bg-white/20 text-white/60'}`}>
                    {i < 3 ? '✓' : '4'}
                  </div>
                  <span class={`text-sm ${i < 3 ? 'text-white' : 'text-white/60'}`}>{step}</span>
                </div>
              ))}
            </div>

            <div class="mt-6 p-3 rounded-xl bg-green-400/20 border border-green-400/30">
              <div class="text-green-300 text-xs font-semibold">🎉 Scholarship Secured</div>
              <div class="text-white text-sm font-bold mt-0.5">₹8,50,000 merit award</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave bottom -->
  <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 fill-(--color-bg)">
      <path d="M0,0 C360,60 1080,60 1440,0 L1440,60 L0,60 Z"/>
    </svg>
  </div>
</section>
