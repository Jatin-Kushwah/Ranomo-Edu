---
import { services } from '@/data/services';

const iconPaths: Record<string, string> = {
  GraduationCap: 'M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0zM22 10v6M6 12.5V16a6 3 0 0 0 12 0v-3.5',
  FileText: 'M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7zM14 2v4a1 1 0 0 0 1 1h4M10 9H8M16 13H8M16 17H8',
  Stamp: 'M5 22h14M9.5 9h5M5 7V4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2zM7 9v4a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9',
  Award: 'M7.21 15 2.66 7.14a2 2 0 0 1 .13-2.2L4.4 3.8A2 2 0 0 1 6 3h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15M11 7 8 15l4 2 4-2-3-8M12 22v-5',
  BookOpen: 'M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z',
  Plane: 'M17.8 19.2 16 11l3.5-3.5C21 6 21 4 21 4s-2 0-3.5 1.5L14 9 5.8 7.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 3.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z',
};
---

<section class="py-20 bg-white" aria-labelledby="services-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14" data-aos="fade-up">
      <span class="text-(--color-primary) font-semibold text-sm uppercase tracking-wider">What We Offer</span>
      <h2 id="services-heading" class="text-3xl sm:text-4xl font-bold text-(--color-dark) mt-2">
        Comprehensive Study Abroad Services
      </h2>
      <p class="text-(--color-text-muted) mt-4 max-w-2xl mx-auto">
        From your first country shortlist to the day you land — we provide end-to-end support so you can focus on your future.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, i) => (
        <div
          class="group rounded-2xl border border-(--color-border) p-7 hover:border-(--color-primary) hover:shadow-lg transition-all duration-300 bg-white"
          data-aos="fade-up"
          data-aos-delay={i * 80}
        >
          <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-5 group-hover:bg-(--color-primary) transition-colors duration-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6 text-(--color-primary) group-hover:text-white transition-colors duration-300"
              aria-hidden="true"
            >
              {iconPaths[service.icon] && iconPaths[service.icon].split('M').filter(Boolean).map((d) => (
                <path d={`M${d}`} />
              ))}
            </svg>
          </div>

          <h3 class="text-lg font-bold text-(--color-dark) mb-2">{service.title}</h3>
          <p class="text-sm text-(--color-text-muted) leading-relaxed mb-4">{service.shortDesc}</p>

          <a
            href={`/services#${service.slug}`}
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-primary) hover:underline"
          >
            Learn More
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
