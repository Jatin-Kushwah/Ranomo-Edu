---
interface Props {
  variant?: 'default' | 'accent' | 'outline' | 'success';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const base = 'inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold';

const variants = {
  default: 'bg-blue-100 text-(--color-primary)',
  accent: 'bg-amber-100 text-amber-800',
  outline: 'border border-(--color-border) text-(--color-text-muted)',
  success: 'bg-green-100 text-green-800',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
